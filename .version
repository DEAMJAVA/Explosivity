mod_name="explosivity"
mod_version="1.0"
game_version="1.21.11"
type="release"   # alpha / beta / release

# --- Naming templates ---
release_pattern="${mod_name}-${mod_version}+${game_version}.jar"
prerelease_pattern="${mod_name}-${mod_version}+${game_version}-${type}%n.jar"

# --- Paths ---
build_dir="build/libs"
move_to="$HOME/deamsmods/Explosivity"
copy_to=("$HOME/deamsmods/")
